# ── Free API Keys ──────────────────────────────────────────
# Groq  → https://console.groq.com  (free, 30 req/min)
GROQ_API_KEY=your_groq_key_here

# Cerebras → https://cloud.cerebras.ai  (free, 60 req/min)
CEREBRAS_API_KEY=your_cerebras_key_here

# DeepSeek → https://platform.deepseek.com  (free, 500k tokens/min)
DEEPSEEK_API_KEY=your_deepseek_key_here

# Mistral → https://console.mistral.ai  (free tier)
MISTRAL_API_KEY=your_mistral_key_here

# Together AI → https://api.together.xyz  ($25 free credits)
TOGETHER_API_KEY=your_together_key_here

# GitHub Models → https://github.com/marketplace/models (free)
GITHUB_TOKEN=your_github_token_here

# ── App Config ─────────────────────────────────────────────
MAX_PAPERS_FETCH=50
TOP_PAPERS_SELECT=10
CHUNK_SIZE=512
CHUNK_OVERLAP=64
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./data/chroma_db
PAPERS_DIR=./data/papers

# ── Server ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
